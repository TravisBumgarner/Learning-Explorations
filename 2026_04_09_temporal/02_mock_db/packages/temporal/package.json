{
  "name": "@mock-db/temporal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc --build",
    "dev": "concurrently --names \"worker\" \"ts-node src/worker.ts\"",
    "start": "ts-node src/worker.ts",
    "test": "mocha --exit --require ts-node/register --require source-map-support/register src/mocha/*.test.ts"
  },
  "exports": {
    "./activities": "./src/activities.ts",
    "./workflows": "./src/workflows.ts"
  },
  "dependencies": {
    "@temporalio/activity": "^1.15.0",
    "@temporalio/client": "^1.15.0",
    "@temporalio/worker": "^1.15.0",
    "@temporalio/workflow": "^1.15.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@temporalio/testing": "^1.15.0",
    "@tsconfig/node22": "^22.0.0",
    "@types/mocha": "8.x",
    "@types/node": "^22.9.1",
    "@types/pg": "^8.11.10",
    "concurrently": "^9.0.0",
    "mocha": "8.x",
    "nodemon": "^3.1.7",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
